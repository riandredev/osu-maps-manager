{
  "name": "@riandredev/osu-maps",
  "version": "1.0.5",
  "description": "A typed CLI for tracking and restoring osu! beatmap collections",
  "author": "Riandre",
  "private": true,
  "type": "module",
  "main": "dist/electron-main.js",
  "bin": {
    "osu-maps": "dist/cli.js"
  },
  "scripts": {
    "assets": "node scripts/build-assets.mjs",
    "build": "pnpm assets && tsc -p tsconfig.json && vite build",
    "dev": "tsx src/cli.ts",
    "gui": "pnpm build && electron .",
    "gui:dev": "pnpm build && electron .",
    "package:win": "pnpm build && electron-builder --win nsis --publish never",
    "sync": "tsx src/cli.ts sync-collection",
    "restore": "tsx src/cli.ts restore",
    "verify": "tsx src/cli.ts verify",
    "readme": "tsx src/cli.ts readme",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "eslint . && prettier --check . && vitest run && tsc -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.7.0",
  "dependencies": {
    "@fluentui/react-components": "^9.72.5",
    "@fluentui/react-icons": "^2.0.316",
    "commander": "^14.0.1",
    "electron-updater": "^6.8.9",
    "prettier": "^3.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "realm": "^20.2.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^38.2.2",
    "electron-builder": "^26.0.12",
    "eslint": "^9.37.0",
    "sharp": "^0.34.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vite": "^7.1.9",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "dev.riandre.osumaps",
    "productName": "osu! Maps Manager",
    "artifactName": "osu-maps-manager-${version}-setup.${ext}",
    "files": [
      "dist/**/*",
      "ui-dist/**/*",
      "assets/**/*",
      "beatmaps.json",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/realm/**"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/app-icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "riandredev",
      "repo": "osu-maps-manager"
    }
  }
}
